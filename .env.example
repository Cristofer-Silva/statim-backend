# ── CAMARA QoD Configuration ──
# Leave empty for simulation mode (default for hackathon demo).
# Fill in to connect to a real telecom operator sandbox.

CAMARA_API_BASE_URL=
CAMARA_CLIENT_ID=
CAMARA_CLIENT_SECRET=
CAMARA_TOKEN_URL=

# ── Simulation Settings ──
SIM_BASE_LATENCY_MS=10.0
SIM_JITTER_RANGE_MS=4.0

# ── Server ──
DEBUG=true
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
